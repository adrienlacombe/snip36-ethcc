# Starknet Sepolia RPC endpoint (e.g., Alchemy, Infura, or self-hosted)
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_KEY

# Master account for the bank (deploys contracts, matches deposits, settles)
STARKNET_ACCOUNT_ADDRESS=0x...
STARKNET_PRIVATE_KEY=0x...

# Sequencer gateway for proof submission
STARKNET_GATEWAY_URL=https://alpha-sepolia.starknet.io

# Optional
# STARKNET_CHAIN_ID=SN_SEPOLIA
# PORT=8090
